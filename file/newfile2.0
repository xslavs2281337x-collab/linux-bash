#!/usr/bin/env bash
function_1() {
if [ -z "$file" ]
then
echo нет названия файла
elif [ ! -f "$file" ]
then
mypwd=$(pwd)
echo "#!/usr/bin/env bash" >> "$mypwd"/"$file"
chmod +x "$mypwd"/"$file"
else echo "$file уже есть"
fi
}

while [ -n "$1" ]
do
case "$1" in
-t)
file="$2"

shift
function_1 ;;
*) echo what? ;;
esac
shift
done


